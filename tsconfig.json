{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/app/perfil.jsx",
    "src/app/suporte.jsx",
    "src/app/pedidos.tsx",
    "src/app/meuServicos.jsx",
    "src/app/editarPerfil.jsx",
    "src/app/login.tsx"
  ]
}